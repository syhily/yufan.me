# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# Site
LOG_LEVEL=

# Server
HOST=0.0.0.0
PORT=4321

# Database
DATABASE_URL=
REDIS_URL=

# Session cookie signing
SESSION_SECRET=

# Analytics (optional)
# Filesystem path to the MaxMind GeoLite2-City mmdb. When unset, the
# analytics ingestion pipeline still records visits but the geo
# columns (country / region / city / lat / lon / timezone) are NULL.
# Download from https://www.maxmind.com/en/geolite2/signup and drop
# the binary at the path below (gitignored by default).
MAXMIND_DB_PATH=./data/maxmind/GeoLite2-City.mmdb
