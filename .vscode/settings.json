{
  "cSpell.customDictionaries": {
    "project-words": {
      "name": "project-words",
      "path": "${workspaceRoot}/docs/project-words.txt",
      "description": "Words used in this project",
      "addWords": true
    },
    "custom": true,
    "internal-terms": false
  },
  "cSpell.language": "en,en-GB",
  "cSpell.ignorePaths": ["package.json", "package-lock.json"],
  "[javascript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "oxc.fmt.configPath": "./oxfmt.config.ts",
  "oxc.disableNestedConfig": true,
  "oxc.requireConfig": true,
  "oxc.tsConfigPath": "./tsconfig.json",
  "oxc.typeAware": true,
  "oxc.useExecPath": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "npm.scriptRunner": "vp",
  "tailwindCSS.experimental.configFile": "src/assets/styles/tailwind.css",
  "tailwindCSS.classFunctions": ["cn"],
  "tailwindCSS.includeLanguages": {
    "mdx": "html"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.experimental.useTsgo": true
}
