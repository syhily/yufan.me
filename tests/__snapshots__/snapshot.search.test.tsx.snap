exports[`snapshot: PostListingBody (search variant) > renders a search results page with posts (pagination suppressed) 1`] = `"<div class="py-4 md:py-6 lg:px-2 2xl:px-12 2xl:py-12"><div class="mx-auto w-full px-3 sm:max-w-sm md:max-w-md lg:max-w-lg xl:max-w-xl 2xl:max-w-2xl"><div class="mb-4 lg:mb-6"><h1 class="post-title text-[1.5rem] md:max-lg:text-[1.625rem] lg:text-[1.75rem] font-bold">【react】搜索结果</h1></div><div class="-mx-1 -mt-2 flex flex-wrap md:-mx-2 md:-mt-4 2xl:-mx-3 2xl:-mt-6"><div class="mt-2 box-border flex max-w-full shrink-0 px-1 md:mt-4 md:px-2 2xl:mt-6 2xl:px-3 w-full md:w-2/3 xl:w-1/2"><div class="relative mb-0 flex min-w-0 flex-1 flex-col wrap-break-word"><div class="relative block flex-1 shrink-0 overflow-hidden aspect-36/17"><a class="group absolute inset-0 rounded-[inherit] border-0 bg-black/10 bg-cover bg-center bg-no-repeat" href="/posts/react-tips" data-discover="true"><img class="block size-full object-cover" src="/images/cover.png" alt="React tips" width="600" height="300" loading="lazy" decoding="async" sizes="(max-width: 768px) 100vw, (max-width: 1280px) 67vw, 50vw" srcSet="" style="filter:brightness(var(--image-brightness));transition:filter 0.3s ease"/><div class="absolute inset-0 size-full bg-surface-secondary/60 opacity-60 transition-opacity duration-300 ease-in-out group-hover:opacity-[0.22]"></div></a></div><div class="absolute inset-x-0 bottom-0 z-1 flex flex-none flex-col p-2 md:px-4 md:py-3"><a class="flex flex-none flex-col" href="/posts/react-tips" data-discover="true"><div class="m-0 mb-2 line-clamp-2 block leading-[1.4] font-semibold text-white hover:text-ink-light hover:[text-shadow:var(--brand)_1px_0_4px]">React tips</div><div class="font-number flex flex-1 text-sm text-ink-overlay"><span class="inline-block">2024-04-01</span><div class="flex-1"></div><div class="ml-2.5 inline-flex items-center gap-1.5 align-middle"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye text-md" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path><circle cx="12" cy="12" r="3"></circle></svg><span class="leading-none">0</span></div><div class="ml-2.5 inline-flex items-center gap-1.5 align-middle"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart text-md" aria-hidden="true"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"></path></svg><span class="leading-none">0</span></div></div></a></div></div></div></div></div></div>"`;

exports[`snapshot: PostListingBody (search variant) > renders the empty-results state for a search query 1`] = `"<div class="py-4 md:py-6 lg:px-2 2xl:px-12 2xl:py-12"><div class="mx-auto w-full px-3 sm:max-w-sm md:max-w-md lg:max-w-lg xl:max-w-xl 2xl:max-w-2xl"><div class="mb-4 lg:mb-6"><h1 class="post-title text-[1.5rem] md:max-lg:text-[1.625rem] lg:text-[1.75rem] font-bold">【react】搜索结果</h1></div><div class="flex h-(--size-empty-state) flex-auto flex-col text-center"><div class="my-auto"><h1 class="font-number text-empty-state-hero">404</h1><div>抱歉，没有你要找的内容...</div></div></div></div></div>"`;
