exports[`snapshot: Sidebar > renders an empty sidebar (every widget hides itself when starved) 1`] = `"<aside class="box-border hidden w-full max-w-full shrink-0 px-3 xl:ml-auto xl:block xl:w-[29%] xl:max-w-[370px]"><div class="mb-7 px-7 py-8 bg-canvas shadow-card xl:sticky xl:top-[30px]"><div id="search" class="mb-10"><form data-discover="true" action="/search" method="get"><label for="sidebar-search-input" class="sr-only">文章寻踪</label><input id="sidebar-search-input" type="search" class="relative block w-full rounded-sm border-0 px-4 py-2 bg-surface transition-colors hover:border-line-muted focus:border-line-muted focus:shadow-none focus:outline-0" placeholder="文章寻踪（输入后回车）" required="" enterKeyHint="search" name="q"/></form></div><div class="mb-10"><h3 tabindex="0" class="relative border-t-2 border-widget-border px-0 py-5 text-base text-brand before:absolute before:-top-0.5 before:left-0 before:h-0.5 before:w-[30px] before:bg-brand before:content-[&#x27;&#x27;]" id="base-ui-_R_dl_">时光只言</h3><img loading="lazy" decoding="async" src="/images/calendar/2026/0424.png" width="600" height="880" alt="今日日历" class="block dark:hidden"/><img loading="lazy" decoding="async" src="/images/calendar/dark/2026/0424.png" width="600" height="880" alt="今日日历" aria-hidden="true" class="hidden dark:block"/></div></div></aside>"`;

