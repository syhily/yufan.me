# React Router / Vite build output
build/
dist/
.zeabur/

# generated framework/content artifacts
.react-router/
.source/

# local caches
.vite/
.cache/

# dependencies
node_modules/
.pnpm-store/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# test output
coverage/

# scratch / probe scripts (e.g. tmp/meting-probe.mjs)
tmp/

# MaxMind GeoLite2 binaries — license forbids redistribution. The
# analytics pipeline reads the path from MAXMIND_DB_PATH at runtime.
data/maxmind/*.mmdb

# environment variables
.env
.env.*
!.env.example

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Hide the SQL session
*.session.sql

# Git Hooks (Vite+ managed runtime dir — the committed hooks live in .vite-hooks/*)
.vite-hooks/_/

.history/

# AI Tools ignore.
.cursor/
.junie/
.trae/
.agents/settings.local.json
.claude/settings.local.json
