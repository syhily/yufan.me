---
import { UnstyledMusicPlayer } from '@/components/mdx/music/UnstyledMusicPlayer'
import { UnstyledSolution } from '@/components/mdx/solutions/UnstyledSolution'
import { getPosts } from '@/services/catalog/schema'

interface Props {
  slug: string
}

const { slug } = Astro.props
const allPosts = await getPosts({ hidden: true, schedule: true })
const post = allPosts.find((post) => post.slug === slug)
if (!post) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const { Content } = await post.render()
---

<Content
  components={{
    MusicPlayer: UnstyledMusicPlayer,
    Solution: UnstyledSolution,
  }}
/>
