---
import type { Page } from '@/helpers/content/schema'

import SeoMeta from '@/components/meta/SeoMeta.astro'

// Compatibility shim: forwards to the unified SeoMeta component. New code
// should import SeoMeta directly. Kept so we don't have to touch every layout
// in this refactor.
export interface Props {
  title?: string
  description?: string
  ogImageUrl?: string
  article?: Page
}

const { title, description, ogImageUrl, article } = Astro.props
const variant = article ? { kind: 'page' as const, article } : { kind: 'website' as const }
---

<SeoMeta {title} {description} {ogImageUrl} {variant} />
