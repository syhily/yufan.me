---
import type { Post } from '@/helpers/content/schema'

import SeoMeta from '@/components/meta/SeoMeta.astro'

// Compatibility shim: forwards to the unified SeoMeta component. New code
// should import SeoMeta directly with `variant={{ kind: 'post', article }}`
// and `canonical`. Kept so we don't have to touch every layout in this PR.
export interface Props {
  title?: string
  description?: string
  requestPath: string
  ogImageUrl?: string
  ogImageAltText: string
  article?: Post
}

const { requestPath, title, description, ogImageUrl, ogImageAltText, article } = Astro.props
const variant = article ? { kind: 'post' as const, article } : { kind: 'website' as const }
---

<SeoMeta {title} {description} pageUrl={requestPath} {ogImageUrl} {ogImageAltText} {variant} canonical />
