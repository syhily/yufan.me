---
import AdminCommentCard from '@/components/admin/AdminCommentCard.astro'
import type { AdminComment } from '@/services/comments/loader'

interface Props {
  comments: AdminComment[]
}

const { comments } = Astro.props
---

{
  comments.length === 0 ? (
    <div class="card">
      <div class="card-body text-center py-5">
        <p class="text-muted mb-0">暂无评论</p>
      </div>
    </div>
  ) : (
    <>
      {comments.map((comment) => (
        <AdminCommentCard {comment} />
      ))}
    </>
  )
}
