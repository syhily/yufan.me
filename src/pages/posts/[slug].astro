---
import { getPost } from '@/helpers/content/schema'
import PostLayout from '@/layouts/PostLayout.astro'

const { slug } = Astro.params
if (!slug) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const post = getPost(slug)
if (!post) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}
---

<PostLayout {post} />
