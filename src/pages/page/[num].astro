---
import config from '@/blog.config'
import { getPosts, getTags } from '@/services/catalog/schema'
import HomeLayout from '@/layouts/HomeLayout.astro'

const { num } = Astro.params

if (!num) {
  Astro.response.status = 500
  throw new Error('No such page num existed.')
}

const pageNum = Number.parseInt(num)
if (pageNum <= 1) {
  return Astro.redirect('/')
}

const [visiblePosts, tags] = await Promise.all([getPosts({ hidden: false, schedule: false }), getTags()])
const total = Math.ceil(visiblePosts.length / config.settings.pagination.posts)
if (pageNum > total) {
  return Astro.redirect(`${total}`, 302)
}
---

<HomeLayout posts={visiblePosts} {pageNum} {tags} />
