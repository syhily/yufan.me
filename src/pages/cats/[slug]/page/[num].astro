---
import config from '@/blog.config'
import { getCategory, getPosts } from '@/services/catalog/schema'
import PostListingLayout from '@/layouts/PostListingLayout.astro'

const { slug, num } = Astro.params
const category = await getCategory(undefined, slug)

if (!category || !num) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const pageNum = Number.parseInt(num)
if (pageNum <= 1) {
  return Astro.redirect(category.permalink)
}

const allPosts = await getPosts({ hidden: true, schedule: false })
const filteredPosts = allPosts.filter((post) => post.category === category.name)
const pageSize = config.settings.pagination.category
const total = Math.ceil(filteredPosts.length / pageSize)

if (pageNum > total) {
  return Astro.redirect(`${total}`, 302)
}
---

<PostListingLayout
  title={category.name}
  description={category.description}
  posts={filteredPosts}
  {pageNum}
  {pageSize}
  rootPath={category.permalink}
/>
