---
import config from '@/blog.config'
import PostListingLayout from '@/layouts/PostListingLayout.astro'
import { getCategory, getPosts } from '@/services/catalog/schema'

const { slug } = Astro.params
const category = await getCategory(undefined, slug)

if (!category) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const allPosts = await getPosts({ hidden: true, schedule: false })
const filteredPosts = allPosts.filter((post) => post.category === category.name)

if (filteredPosts.length === 0) {
  return Astro.rewrite('/404')
}
---

<PostListingLayout
  title={category.name}
  description={category.description}
  posts={filteredPosts}
  pageNum={1}
  pageSize={config.settings.pagination.category}
  rootPath={category.permalink}
/>
