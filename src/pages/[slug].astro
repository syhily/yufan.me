---
import { getPage } from '@/helpers/content/schema'
import PageLayout from '@/layouts/PageLayout.astro'

const { slug } = Astro.params
if (!slug) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const page = getPage(slug)
if (!page) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}
---

<PageLayout {page} />
