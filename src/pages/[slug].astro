---
import { MusicPlayer } from '@/components/mdx/music/MusicPlayer'
import { Friends } from '@/components/mdx/page/Friends'
import { Solution } from '@/components/mdx/solutions/Solution'
import { SeoMeta } from '@/components/meta/SeoMeta'
import { PageDetailBody } from '@/components/page/post/PageDetailBody'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getPage } from '@/services/catalog/schema'
import { Image } from 'astro:assets'

const { slug } = Astro.params
if (!slug) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const page = await getPage(slug)
if (!page) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const { Content, headings } = await page.render()
---

<BaseLayout title={page.title} description={page.summary} footer={false}>
  <SeoMeta
    slot="og"
    title={page.title}
    description={page.summary}
    ogImageUrl={page.og ? page.og : `/images/og/${page.slug}.png`}
    variant={{ kind: 'page', article: page }}
  />
  <PageDetailBody page={page} headings={headings} session={Astro.session}>
    <Content components={{ img: Image, Friends, MusicPlayer, Solution }} />
  </PageDetailBody>
</BaseLayout>
