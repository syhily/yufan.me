---
import { LoginForm } from '@/components/admin/LoginForm'
import AdminLayout from '@/layouts/AdminLayout.astro'
import { logout, userSession } from '@/services/auth/session'
import { actions } from 'astro:actions'

if (Astro.session === undefined) {
  throw new Error('Please configure your astro session store')
}

const action = Astro.url.searchParams.get('action')
if (action === 'logout') {
  logout(Astro.session)
  return Astro.redirect(Astro.url.searchParams.get('redirect_to') || import.meta.env.SITE)
}

const user = await userSession(Astro.session)
if (user !== undefined) {
  return Astro.redirect(Astro.url.searchParams.get('redirect_to') || import.meta.env.SITE)
}

const signInAction = `?${actions.auth.signIn.queryString}`
---

<AdminLayout title="用户登陆">
  <LoginForm action={signInAction} session={Astro.session} />
</AdminLayout>

<script>
  import '@/assets/scripts/admin/login'
</script>
