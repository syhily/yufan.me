---
import config from '@/blog.config'
import PostListingLayout from '@/layouts/PostListingLayout.astro'
import { getPosts, getTag } from '@/services/catalog/schema'

const { slug } = Astro.params
const tag = await getTag(undefined, slug)

if (!tag) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const allPosts = await getPosts({ hidden: true, schedule: false })
const filteredPosts = allPosts.filter((post) => post.tags.includes(tag.name))
---

<PostListingLayout
  title={`标签 “${tag.name}”`}
  posts={filteredPosts}
  pageNum={1}
  pageSize={config.settings.pagination.tags}
  rootPath={tag.permalink}
  redirectIfEmpty
/>
