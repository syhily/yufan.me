---
import config from '@/blog.config'
import { getPosts, getTag } from '@/services/catalog/schema'
import PostListingLayout from '@/layouts/PostListingLayout.astro'

const { slug, num } = Astro.params
const tag = await getTag(undefined, slug)

if (!tag || !num) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const pageNum = Number.parseInt(num)
if (pageNum <= 1) {
  return Astro.redirect(tag.permalink)
}

const allPosts = await getPosts({ hidden: true, schedule: false })
const filteredPosts = allPosts.filter((post) => post.tags.includes(tag.name))
const pageSize = config.settings.pagination.tags
const total = Math.ceil(filteredPosts.length / pageSize)

if (pageNum > total) {
  return Astro.redirect(`${total}`, 302)
}
---

<PostListingLayout
  title={`标签 “${tag.name}”`}
  posts={filteredPosts}
  {pageNum}
  {pageSize}
  rootPath={tag.permalink}
  redirectIfEmpty
/>
