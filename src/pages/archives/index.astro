---
import { getPosts, getPostsWithMetadata } from '@/services/catalog/schema'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { ArchivesBody } from '@/components/page/archives/ArchivesBody'

const title = '归档'

const currentPosts = await getPosts({ hidden: false, schedule: false })
const resolvedPosts = await getPostsWithMetadata(currentPosts, {
  likes: true,
  views: true,
  comments: false,
})
---

<BaseLayout {title}>
  <ArchivesBody {resolvedPosts} />
</BaseLayout>
