---
import type { Post } from '@/services/catalog/schema'

import { SeoMeta } from '@/components/meta/SeoMeta'
import { slicePosts } from '@/services/markdown/formatter'
import { getPostsWithMetadata } from '@/services/catalog/schema'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { PostListingBody, computePostListingSeoProps } from '@/layouts/PostListingLayout'

// Generic "title + grid + pagination" page used by Category, Tag, Search and
// any future listing-style page. Two calling styles are supported:
//
//  1. Internal pagination (default): pass the full `posts` array plus
//     `pageNum` / `pageSize`; this layout slices the slice it needs and
//     computes the total page count.
//  2. Pre-paginated: callers that already paginated upstream (search via
//     FlexSearch is the only one today) pass `presliced = { current, total }`
//     and the `posts` array is treated as the current page's slice as-is.
//
// Whenever you find yourself wanting a slightly different layout for a new
// listing surface, prefer adding a new prop here over forking the component.
interface Props {
  title: string
  description?: string
  posts: Post[]
  pageNum: number
  pageSize?: number
  rootPath: string
  /** When the slice is empty, fall through to a 404 redirect. */
  redirectIfEmpty?: boolean
  /** When the requested page is below 1, redirect to this path. */
  redirectOnUnderflow?: string
  /** Render even when only a single page exists (useful for search results). */
  alwaysRenderPagination?: boolean
  /**
   * Skip internal pagination — callers that already paginated upstream
   * supply the current/total page numbers and `posts` is the page slice.
   */
  presliced?: { current: number; total: number }
  /** Force a `<meta name="robots" content="noindex">` regardless of pageNum. */
  forceNoindex?: boolean
}

const {
  title,
  description,
  posts,
  pageNum,
  pageSize,
  rootPath,
  redirectIfEmpty = false,
  redirectOnUnderflow,
  alwaysRenderPagination = true,
  presliced,
  forceNoindex = false,
} = Astro.props

if (redirectOnUnderflow !== undefined && pageNum < 1) {
  return Astro.redirect(redirectOnUnderflow)
}

let currentPosts: Post[]
let totalPage: number
if (presliced) {
  currentPosts = posts
  totalPage = presliced.total
} else {
  if (pageSize === undefined) {
    throw new Error('PostListingLayout: `pageSize` is required when `presliced` is not provided.')
  }
  ;({ currentPosts, totalPage } = slicePosts(posts, pageNum, pageSize))
}

if (redirectIfEmpty && totalPage === 0) {
  return Astro.rewrite('/404')
}

const resolvedPosts = await getPostsWithMetadata(currentPosts, {
  likes: true,
  views: true,
  comments: false,
})

const { pageTitle, canonicalUrl, prevUrl, nextUrl, noindex } = computePostListingSeoProps({
  title,
  pageNum,
  totalPage,
  rootPath,
  forceNoindex,
})
---

<BaseLayout title={pageTitle}>
  <SeoMeta
    slot="og"
    title={pageTitle}
    description={description}
    pageUrl={canonicalUrl}
    canonical
    prevUrl={prevUrl}
    nextUrl={nextUrl}
    noindex={noindex}
  />
  <PostListingBody {title} {description} {resolvedPosts} {pageNum} {totalPage} {rootPath} {alwaysRenderPagination} />
</BaseLayout>
