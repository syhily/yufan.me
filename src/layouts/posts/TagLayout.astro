---
import type { Post, Tag } from '@/helpers/content/schema'

import config from '@/blog.config'
import PostListLayout from '@/layouts/posts/PostListLayout.astro'

interface Props {
  tag: Tag
  posts: Post[]
  pageNum: number
}

const { tag, posts, pageNum } = Astro.props
---

<PostListLayout
  title={`标签 “${tag.name}”`}
  {posts}
  {pageNum}
  pageSize={config.settings.pagination.tags}
  rootPath={tag.permalink}
  redirectIfEmpty
/>
