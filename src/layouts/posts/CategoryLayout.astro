---
import type { Category, Post } from '@/helpers/content/schema'

import config from '@/blog.config'
import PostListLayout from '@/layouts/posts/PostListLayout.astro'

interface Props {
  category: Category
  posts: Post[]
  pageNum: number
}

const { category, posts, pageNum } = Astro.props
---

<PostListLayout
  title={category.name}
  description={category.description}
  {posts}
  {pageNum}
  pageSize={config.settings.pagination.category}
  rootPath={category.permalink}
/>
