---
import type { Post } from '@/helpers/content/schema'

import Pagination from '@/components/page/pagination/Pagination.astro'
import PostSquare from '@/components/page/post/PostSquare.astro'
import { slicePosts } from '@/helpers/content/formatter'
import { getPostsWithMetadata } from '@/helpers/content/schema'
import BaseLayout from '@/layouts/BaseLayout.astro'

// Generic "title + grid + pagination" page used by Category, Tag and Search
// listing pages. The previous TagLayout / CategoryLayout / SearchLayout files
// duplicated this exact frontmatter and markup; if you find yourself needing
// a slightly different layout, prefer adding a new prop here over forking the
// component again.
interface Props {
  title: string
  description?: string
  posts: Post[]
  pageNum: number
  pageSize: number
  rootPath: string
  /** When the slice is empty, fall through to a 404 redirect. */
  redirectIfEmpty?: boolean
  /** When the requested page is below 1, redirect to this path. */
  redirectOnUnderflow?: string
  /** Render even when only a single page exists (for Search results). */
  alwaysRenderPagination?: boolean
}

const {
  title,
  description,
  posts,
  pageNum,
  pageSize,
  rootPath,
  redirectIfEmpty = false,
  redirectOnUnderflow,
  alwaysRenderPagination = true,
} = Astro.props

if (redirectOnUnderflow !== undefined && pageNum < 1) {
  return Astro.redirect(redirectOnUnderflow)
}

const { currentPosts, totalPage } = slicePosts(posts, pageNum, pageSize)

if (redirectIfEmpty && totalPage === 0) {
  return Astro.rewrite('/404')
}

const resolvedPosts = await getPostsWithMetadata(currentPosts, {
  likes: true,
  views: true,
  comments: false,
})
---

<BaseLayout {title}>
  <div class="px-lg-2 px-xxl-5 py-3 py-md-4 py-xxl-5">
    <div class="container">
      <div class="mb-3 mb-lg-4">
        <h1>{title}</h1>
        {
          description && (
            <div class="text-muted mt-1">
              <Fragment set:html={description} />
            </div>
          )
        }
      </div>
      {
        resolvedPosts.length === 0 ? (
          <div class="data-null">
            <div class="my-auto">
              <h1 class="font-number">404</h1>
              <div>抱歉，没有你要找的内容...</div>
            </div>
          </div>
        ) : (
          <>
            <div class="row g-2 g-md-3 g-xxl-4 list-grouped">
              {resolvedPosts.map((post, index) => (
                <PostSquare post={post} first={index === 0} />
              ))}
            </div>
            {(alwaysRenderPagination || totalPage > 1) && (
              <div class="mt-4 mt-lg-5">
                <Pagination current={pageNum} total={totalPage} {rootPath} />
              </div>
            )}
          </>
        )
      }
    </div>
  </div>
</BaseLayout>
