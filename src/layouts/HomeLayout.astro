---
import type { Post, Tag } from '@/services/catalog/schema'
import { SeoMeta } from '@/components/meta/SeoMeta'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { HomeLayoutBody, computeHomeSeoProps } from '@/layouts/HomeLayout'

interface Props {
  posts: Post[]
  pageNum: number
  tags: Tag[]
}

const { posts, pageNum, tags } = Astro.props

// Redirect to the homepage.
if (pageNum < 1) {
  return Astro.redirect('/')
}

const { pageTitle, canonicalUrl, prevUrl, nextUrl, noindex } = computeHomeSeoProps(posts, pageNum)
---

<BaseLayout title={pageTitle}>
  <SeoMeta
    slot="og"
    title={pageTitle}
    pageUrl={canonicalUrl}
    canonical
    prevUrl={prevUrl}
    nextUrl={nextUrl}
    noindex={noindex}
  />
  <HomeLayoutBody {posts} {pageNum} {tags} session={Astro.session}>
    <slot />
  </HomeLayoutBody>
</BaseLayout>
