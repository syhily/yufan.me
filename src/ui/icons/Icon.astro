---
// Inline SVG icon renderer.
//
// Each icon under `src/assets/icons/*.svg` is registered eagerly with Vite's
// glob import. With `experimental.svg = true`, Astro 6 turns each `.svg`
// import into an inline component, so we ship one tiny inline `<svg>` per
// usage site instead of a 600-glyph icon font. Use `<Icon name="search" />`
// from anywhere — Astro tree-shakes any glyph that no template references.

const modules = import.meta.glob<unknown>('@/assets/icons/*.svg', {
  eager: true,
  import: 'default',
})

const icons: Record<string, unknown> = {}
for (const [path, mod] of Object.entries(modules)) {
  const name = path
    .split('/')
    .pop()!
    .replace(/\.svg$/, '')
  icons[name] = mod
}

const { name, size, title, class: className, ...rest } = Astro.props

const Svg = icons[name] as ((props: Record<string, unknown>) => unknown) | undefined
if (!Svg) {
  throw new Error(`Unknown icon: ${name}. Add the SVG to src/assets/icons/${name}.svg`)
}

// Source SVGs (from iconfont/Iconpark exports) only declare a `viewBox` and no
// intrinsic width/height. Without a sizing hint, browsers fall back to the
// 1024px viewBox dimensions, which makes random icons render gigantic in flex
// rows. Default to `1em` so the icon always tracks the surrounding font-size
// — the `.icon` rule in globals.css provides the matching CSS fallback.
const dim = size ?? '1em'
---

<Svg
  width={dim}
  height={dim}
  class:list={['icon', `icon-${name}`, className]}
  aria-hidden={title ? undefined : 'true'}
  role={title ? 'img' : undefined}
  focusable="false"
  fill="currentColor"
  {...rest}
>
  {title && <title>{title}</title>}
</Svg>
